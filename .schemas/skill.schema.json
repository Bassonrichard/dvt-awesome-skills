{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DVT Skill frontmatter",
  "description": "Frontmatter schema for skills/<name>/SKILL.md",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 2,
      "maxLength": 64,
      "description": "Lowercase-hyphen identifier; must match the folder name."
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1024,
      "description": "What the skill does and when to use it."
    },
    "metadata": {
      "type": "object",
      "properties": {
        "tools": {
          "type": "array",
          "items": { "enum": ["copilot", "cursor", "windsurf", "claude", "kiro"] },
          "uniqueItems": true,
          "description": "Targets to generate for. Omit or empty = all tools."
        },
        "category": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
